# No build stage needed - Lua files are loaded directly by Nakama
FROM registry.heroiclabs.com/heroiclabs/nakama:3.22.0

# Copy Lua module (no compilation required)
COPY lua-modules/main.lua /nakama/data/modules/main.lua

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
